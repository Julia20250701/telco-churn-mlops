############################################################
# MLFLOW MODE
############################################################

# local  -> use local MLflow server
# dagshub -> use DagsHub MLflow tracking

MLFLOW_MODE=local


############################################################
# LOCAL MLFLOW
############################################################

MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT_NAME=telco-churn-local


############################################################
# DAGSHUB MLFLOW
############################################################

DAGSHUB_USER=your_dagshub_username
DAGSHUB_REPO=telco-churn-mlops
DAGSHUB_MLFLOW_TRACKING_URI=https://dagshub.com/your_dagshub_username/telco-churn-mlops.mlflow

MLFLOW_TRACKING_USERNAME=your_dagshub_username
MLFLOW_TRACKING_PASSWORD=your_dagshub_token

MLFLOW_EXPERIMENT_NAME_REMOTE=telco-churn


############################################################
# MODEL REGISTRY
############################################################

REGISTERED_MODEL_NAME=telco-churn-classifier
MODEL_ALIAS=candidate


############################################################
# PREDICT API CONFIG
############################################################

# 1 = load from MLflow Registry
# 0 = load from local file
PREDICT_LOAD_FROM_REGISTRY=1

# only used when PREDICT_LOAD_FROM_REGISTRY=0
LOCAL_MODEL_PATH=artifacts/baseline/latest/model.joblib


############################################################
# FASTAPI
############################################################

PREDICT_API_HOST=0.0.0.0
PREDICT_API_PORT=8000
